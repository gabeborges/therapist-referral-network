# Non-secret defaults for local development
# This file is committed to the repo. NEVER put secrets here.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
RESEND_FROM_EMAIL=Therapist Referral Network <noreply@therapistreferralnetwork.com>
DRIP_BATCH_SIZE=7
DRIP_MAX_BATCHES=5
DRIP_FOLLOWUP_HOURS=48
DRIP_NEXT_BATCH_DELAY_HOURS=1

# MailerLite (actual key in .env.local)
MAILERLITE_API_KEY=

# Google Tag Manager (leave empty to disable)
NEXT_PUBLIC_GTM_ID=
