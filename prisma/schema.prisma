generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// === Auth.js required models ===

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  therapistProfile TherapistProfile?

  agreedToTermsAt DateTime?
  termsVersion    String?

  // Soft-delete for account deletion workflow (PIPEDA data retention)
  deletedAt    DateTime?
  deleteReason String?   // "user_request" | "admin"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// === Taxonomy tables ===

model Specialty {
  id        String @id @default(cuid())
  name      String @unique
  category  String? // "Mental Health", "Sexuality", or null for main list
  sortOrder Int    @default(0)

  profiles TherapistProfile[] @relation("ProfileSpecialties")

  createdAt DateTime @default(now())
}

model TherapyType {
  id        String @id @default(cuid())
  name      String @unique
  sortOrder Int    @default(0)

  profiles TherapistProfile[] @relation("ProfileTherapyTypes")

  createdAt DateTime @default(now())
}

model Language {
  id        String @id @default(cuid())
  name      String @unique
  sortOrder Int    @default(0)

  profiles TherapistProfile[] @relation("ProfileLanguages")

  createdAt DateTime @default(now())
}

model AlliedGroup {
  id        String @id @default(cuid())
  name      String @unique
  sortOrder Int    @default(0)

  profiles TherapistProfile[] @relation("ProfileGroups")

  createdAt DateTime @default(now())
}

model PaymentMethod {
  id        String @id @default(cuid())
  name      String @unique
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
}

// === Domain models ===

model TherapistProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Professional info
  firstName   String
  middleName  String?
  lastName    String
  displayName String
  bio         String?

  // Identity
  imageUrl          String?
  pronouns          String?
  therapistGender   String?
  primaryCredential String?  // e.g., "Registered Psychotherapist"
  credentials       String[] // post-nominal letters, max 3

  // Practice details
  websiteUrl         String?
  psychologyTodayUrl String?
  contactEmail       String?
  licensingLevel     String?  // "Fully Licensed" | "Supervised Practice" | "Practicum Student"
  freeConsultation   Boolean  @default(false)

  // Location
  city     String
  province String
  country  String @default("CA")

  // Practice details (legacy String[] — kept during migration)
  specialties         String[] // taxonomy IDs
  modalities          String[] // ["in-person", "virtual", "phone"]
  therapeuticApproach String[] // therapy type names from taxonomy
  languages           String[] // language names from taxonomy
  ages                String[] // ["Toddler", "Children (6-10)", "Preteen", "Teen", "Adults", "Elders (65+)"]

  // Taxonomy relations (replacing String[] above)
  specialtyRecords     Specialty[]     @relation("ProfileSpecialties")
  therapyTypeRecords   TherapyType[]   @relation("ProfileTherapyTypes")
  languageRecords      Language[]      @relation("ProfileLanguages")
  groupRecords         AlliedGroup[]   @relation("ProfileGroups")

  // Consent
  consentCommunitiesServed Boolean @default(false)

  // Communities served
  participants     String[] // ["Individual", "Couples", "Family", "Group"]
  topSpecialties   String[] // max 3, ordered
  faithOrientation String[]
  ethnicity        String[]
  therapyStyle     String[] // ["Structured", "Direct", "Relational", etc.]

  // Insurance & pricing
  insurers         String[] // specific insurers accepted
  paymentMethods   String[] // payment instruments: "Visa", "Cash", "Direct billing", etc.
  rateIndividual   Int?     // in cents
  rateGroup        Int?     // in cents
  rateFamily       Int?     // in cents
  rateCouples      Int?     // in cents
  proBono          Boolean  @default(false)
  reducedFees      Boolean  @default(false)
  acceptsInsurance Boolean  @default(false)

  // Availability
  acceptingClients Boolean @default(true)

  // Activity tracking (for matching rank decay)
  lastActiveAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  postedReferrals       ReferralPost[]          @relation("PostedReferrals")
  receivedNotifications ReferralNotification[]   @relation("ReceivedNotifications")

  @@index([country, province, city])
  @@index([acceptingClients, country])
}

// === Referral models ===

enum ReferralStatus {
  OPEN
  FULFILLED
  CANCELLED
  EXPIRED
}

model ReferralPost {
  id       String           @id @default(cuid())
  authorId String
  author   TherapistProfile @relation("PostedReferrals", fields: [authorId], references: [id], onDelete: Cascade)

  // Referral criteria
  presentingIssue String
  ageGroup        String[]
  city            String?
  province        String?
  modalities      String[] // ["in-person", "virtual", "phone"]
  details         String?

  // Expanded referral fields
  insuranceRequired   Boolean  @default(false) // Match therapists with acceptsInsurance
  participants        String[] // ["Individual", "Couples", "Family", "Group"]
  rate                String?  // "Full fee" | "Sliding scale" | "Pro-bono"
  therapistGenderPref String?  // "Any" | "Female" | "Male" | "Non-binary"
  therapyTypes        String[] // Therapy type names from taxonomy
  languages           String[] // Language names from taxonomy
  additionalContext   String?  // Extended free text for nuance

  // Status
  status      ReferralStatus @default(OPEN)
  fulfilledAt DateTime?
  cancelledAt DateTime?

  // Drip tracking
  currentBatch  Int       @default(0)
  lastDrippedAt DateTime?

  // Shareable link
  slug String @unique @default(cuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications     ReferralNotification[]
  fulfillmentChecks FulfillmentCheck[]

  @@index([status, createdAt])
  @@index([authorId, createdAt(sort: Desc)])
}

model ReferralNotification {
  id             String           @id @default(cuid())
  referralPostId String
  referralPost   ReferralPost     @relation(fields: [referralPostId], references: [id], onDelete: Cascade)
  recipientId    String
  recipient      TherapistProfile @relation("ReceivedNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  batch   Int          // Which drip batch this was sent in
  sentAt  DateTime     @default(now())
  emailId String?      // Resend email ID for tracking

  @@unique([referralPostId, recipientId])
  @@index([referralPostId, batch])
  @@index([recipientId, sentAt(sort: Desc)])
}

model FulfillmentCheck {
  id             String       @id @default(cuid())
  referralPostId String
  referralPost   ReferralPost @relation(fields: [referralPostId], references: [id], onDelete: Cascade)

  sentAt      DateTime  @default(now())
  respondedAt DateTime?
  fulfilled   Boolean?  // null = pending, true = yes, false = no

  token String @unique @default(uuid()) // Cryptographically random token for email link

  @@index([referralPostId])
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  country   String   // "US" or other non-CA countries
  createdAt DateTime @default(now())
}

// === Data retention / compliance ===

// Consent audit log — no FK to User so records survive account hard-deletion.
// Retained for 24 months after account closure as compliance proof (PIPEDA).
model ConsentLog {
  id            String   @id @default(cuid())
  userId        String
  consentType   String   // "terms" | "communities_served" | "account_deletion"
  action        String   // "granted" | "withdrawn"
  policyVersion String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([userId, consentType])
  @@index([createdAt])
}
